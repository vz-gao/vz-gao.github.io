---
const { title } = Astro.props.frontmatter || Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            background-color: #f4f4f9;
            color: #333;
        }
        h1 { color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 0.5rem; }
        h2 { color: #2980b9; margin-top: 2rem; }
        code { background: #eee; padding: 0.2rem 0.4rem; border-radius: 4px; }
        footer { margin-top: 3rem; font-size: 0.9rem; color: #7f8c8d; border-top: 1px solid #ddd; padding-top: 1rem; }
        a { color: #3498db; text-decoration: none; }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <main>
        <slot />
    </main>
    <footer>
        <p>&copy; 2026 Yudiaochan's Blog. Built with Astro & AI Agent.</p>
        <p><a href="/">← 返回首页</a></p>
    </footer>
</body>
</html>
